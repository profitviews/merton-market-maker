set shell := ["bash", "-cu"]

module_name := "merton_online_calibrator.so"
root := justfile_directory()

default:
  @just test

setup-defaults:
  #!/usr/bin/env bash
  set -euo pipefail
  cfg="{{root}}/.merton-build.env"
  if [ -f "$cfg" ]; then
    printf "A defaults file already exists at %s. Overwrite it? [y/N]: " "$cfg"
    read -r overwrite
    case "$overwrite" in
      y|Y|yes|YES) ;;
      *) echo "Keeping existing defaults."; exit 0 ;;
    esac
  fi

  echo
  echo "Merton Market Maker build setup"
  echo "This stores your preferred build defaults in cpp/.merton-build.env."
  echo "Environment variables still override these values when needed."
  echo

  echo "1) Python version (PY_VER)"
  echo "   Controls the Python ABI used to build the extension module."
  echo "   Use the same major.minor version as the target runtime (ProfitView is typically 3.9)."
  printf "   Python version [3.9]: "
  read -r pyver
  pyver=${pyver:-3.9}

  echo
  echo "2) Ubuntu version (UBUNTU_VERSION)"
  echo "   Base image used for the Docker build environment."
  echo "   Keep this aligned with the runtime or toolchain expectations unless you have a reason to change it."
  printf "   Ubuntu version [22.04]: "
  read -r ubuntu_ver
  ubuntu_ver=${ubuntu_ver:-22.04}

  echo
  echo "3) Python binding backend (MERTON_PYTHON_BINDING)"
  echo "   - nanobind: current default, smaller/faster binding layer, now produces plain merton_online_calibrator.so"
  echo "   - pybind11: alternative backend, also supported and tested"
  while :; do
    printf "   Binding backend [nanobind]: "
    read -r binding
    binding=${binding:-nanobind}
    case "$binding" in
      nanobind|pybind11) break ;;
      *) echo "   Please enter 'nanobind' or 'pybind11'." ;;
    esac
  done

  echo
  echo "4) Docker networking mode (DOCKER_NETWORK)"
  echo "   - host: recommended on this machine; avoids Docker DNS issues seen with bridge mode"
  echo "   - bridge: standard Docker isolation if your network works there"
  while :; do
    printf "   Docker network [host]: "
    read -r docker_network
    docker_network=${docker_network:-host}
    case "$docker_network" in
      host|bridge) break ;;
      *) echo "   Please enter 'host' or 'bridge'." ;;
    esac
  done

  echo
  echo "5) Docker image name (IMAGE_NAME)"
  echo "   Local tag for the build image used by just recipes."
  printf "   Image name [merton-refl-build]: "
  read -r image_name
  image_name=${image_name:-merton-refl-build}

  echo
  echo "6) Optional module copy destination (MODULE_DEST_DIR)"
  echo "   If set, build recipes will copy merton_online_calibrator.so there after a successful build."
  echo "   This is useful for an sshfs-mounted ProfitView container directory. Leave blank to skip copying."
  printf "   Destination directory [blank]: "
  read -r module_dest_dir

  printf '%s\n' \
    '# Generated by: just setup-defaults' \
    '# Override any of these temporarily by prefixing the just command with env vars.' \
    "PY_VER=$pyver" \
    "UBUNTU_VERSION=$ubuntu_ver" \
    "MERTON_PYTHON_BINDING=$binding" \
    "DOCKER_NETWORK=$docker_network" \
    "IMAGE_NAME=$image_name" \
    "MODULE_DEST_DIR=$module_dest_dir" \
    > "$cfg"

  echo
  echo "Saved defaults to $cfg"
  just show-defaults

show-defaults:
  #!/usr/bin/env bash
  set -euo pipefail
  cfg="{{root}}/.merton-build.env"
  if [ -f "$cfg" ]; then
    source "$cfg"
  fi
  image_name="${IMAGE_NAME:-merton-refl-build}"
  pyver="${PY_VER:-3.9}"
  ubuntu_ver="${UBUNTU_VERSION:-22.04}"
  binding="${MERTON_PYTHON_BINDING:-nanobind}"
  docker_network="${DOCKER_NETWORK:-host}"
  module_dest_dir="${MODULE_DEST_DIR:-}"
  echo "Effective defaults:"
  echo "  IMAGE_NAME=$image_name"
  echo "  PY_VER=$pyver"
  echo "  UBUNTU_VERSION=$ubuntu_ver"
  echo "  MERTON_PYTHON_BINDING=$binding"
  echo "  DOCKER_NETWORK=$docker_network"
  echo "  MODULE_DEST_DIR=$module_dest_dir"

docker-build:
  #!/usr/bin/env bash
  set -euo pipefail
  cfg="{{root}}/.merton-build.env"
  if [ -f "$cfg" ]; then
    source "$cfg"
  fi
  image_name="${IMAGE_NAME:-merton-refl-build}"
  pyver="${PY_VER:-3.9}"
  ubuntu_ver="${UBUNTU_VERSION:-22.04}"
  docker_network="${DOCKER_NETWORK:-host}"
  docker build --network="$docker_network" -t "$image_name" \
    --build-arg UBUNTU_VERSION="$ubuntu_ver" \
    --build-arg PYTHON_VERSION="$pyver" \
    -f "{{root}}/Dockerfile" \
    "{{root}}"

build-host: docker-build
  #!/usr/bin/env bash
  set -euo pipefail
  cfg="{{root}}/.merton-build.env"
  if [ -f "$cfg" ]; then
    source "$cfg"
  fi
  image_name="${IMAGE_NAME:-merton-refl-build}"
  pyver="${PY_VER:-3.9}"
  binding="${MERTON_PYTHON_BINDING:-nanobind}"
  docker_network="${DOCKER_NETWORK:-host}"
  module_dest_dir="${MODULE_DEST_DIR:-}"
  docker run --network "$docker_network" --rm -v "{{root}}:/workspace" "$image_name" bash -lc "rm -rf /workspace/build && cmake -S /workspace -B /workspace/build -G Ninja -DCMAKE_TOOLCHAIN_FILE=/workspace/toolchain-p2996.cmake -DPython3_EXECUTABLE=/usr/bin/python$pyver -DMERTON_PYTHON_BINDING=$binding && cmake --build /workspace/build"
  if [ -n "$module_dest_dir" ]; then
    install -d "$module_dest_dir"
    cp -f "{{root}}/build/{{module_name}}" "$module_dest_dir/"
  fi

test-host: build-host
  #!/usr/bin/env bash
  set -euo pipefail
  cfg="{{root}}/.merton-build.env"
  if [ -f "$cfg" ]; then
    source "$cfg"
  fi
  image_name="${IMAGE_NAME:-merton-refl-build}"
  pyver="${PY_VER:-3.9}"
  docker_network="${DOCKER_NETWORK:-host}"
  docker run --network "$docker_network" --rm -v "{{root}}:/workspace" "$image_name" bash -lc "PYTHONPATH=/workspace/build python$pyver -m pytest /workspace/tests"

copy-module:
  #!/usr/bin/env bash
  set -euo pipefail
  cfg="{{root}}/.merton-build.env"
  if [ -f "$cfg" ]; then
    source "$cfg"
  fi
  module_dest_dir="${MODULE_DEST_DIR:-}"
  if [ -z "$module_dest_dir" ]; then
    echo "Set MODULE_DEST_DIR in cpp/.merton-build.env or override it for this command."
    exit 1
  fi
  install -d "$module_dest_dir"
  cp -f "{{root}}/build/{{module_name}}" "$module_dest_dir/"

# Interactive shell with clang++ (p2996) and QuantLib on PATH for ad-hoc compilation.
shell:
  #!/usr/bin/env bash
  set -euo pipefail
  cfg="{{root}}/.merton-build.env"
  if [ -f "$cfg" ]; then
    source "$cfg"
  fi
  image_name="${IMAGE_NAME:-merton-refl-build}"
  docker run -it --rm -v "{{root}}:/workspace" -w /workspace "$image_name" bash

# Run p2996 clang++ in container; mounts current dir. Usage: just clang-pp -- -std=c++20 -o prog prog.cpp
clang-pp *ARGS:
  #!/usr/bin/env bash
  set -euo pipefail
  cfg="{{root}}/.merton-build.env"
  if [ -f "$cfg" ]; then
    source "$cfg"
  fi
  image_name="${IMAGE_NAME:-merton-refl-build}"
  docker run --rm -v "$PWD:/workspace" -w /workspace "$image_name" clang++ {{ARGS}}

build-local:
  #!/usr/bin/env bash
  set -euo pipefail
  cfg="{{root}}/.merton-build.env"
  if [ -f "$cfg" ]; then
    source "$cfg"
  fi
  pyver="${PY_VER:-3.9}"
  binding="${MERTON_PYTHON_BINDING:-nanobind}"
  module_dest_dir="${MODULE_DEST_DIR:-}"
  rm -rf "{{root}}/build"
  cmake -S "{{root}}" -B "{{root}}/build" -G Ninja \
    -DCMAKE_TOOLCHAIN_FILE="{{root}}/toolchain-p2996.cmake" \
    -DPython3_EXECUTABLE="/usr/bin/python$pyver" \
    -DMERTON_PYTHON_BINDING="$binding"
  cmake --build "{{root}}/build"
  if [ -n "$module_dest_dir" ]; then
    install -d "$module_dest_dir"
    cp -f "{{root}}/build/{{module_name}}" "$module_dest_dir/"
  fi

test-local: build-local
  #!/usr/bin/env bash
  set -euo pipefail
  cfg="{{root}}/.merton-build.env"
  if [ -f "$cfg" ]; then
    source "$cfg"
  fi
  pyver="${PY_VER:-3.9}"
  PYTHONPATH="{{root}}/build" "python$pyver" -m pytest "{{root}}/tests"

# Smart defaults:
# - On host (docker available): run host recipes
# - In container (docker unavailable): run local recipes
build:
  if command -v docker >/dev/null 2>&1; then just build-host; else just build-local; fi

test:
  if command -v docker >/dev/null 2>&1; then just test-host; else just test-local; fi
